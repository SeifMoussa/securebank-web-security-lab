# Local development settings only. Do not commit real secrets.
SECUREBANK_ENV=development
SECUREBANK_DEBUG=true
SECUREBANK_DATABASE_URL=sqlite:///./securebank_lab.sqlite3
SECUREBANK_SECRET_KEY=change-me-in-local-development
SECUREBANK_SESSION_COOKIE_NAME=securebank_lab_session
SECUREBANK_SESSION_MAX_AGE_SECONDS=3600
SECUREBANK_CSRF_COOKIE_NAME=securebank_lab_csrf
SECUREBANK_CSRF_TOKEN_MAX_AGE_SECONDS=3600
SECUREBANK_SECURE_COOKIE=false
SECUREBANK_HSTS_ENABLED=false
SECUREBANK_SEED_DEMO_DATA=true

# Container example:
# SECUREBANK_DATABASE_URL=sqlite:////data/securebank_lab.sqlite3
